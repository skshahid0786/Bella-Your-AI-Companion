// ============================================================
//  firestore.rules  — Paste this into Firebase Console > Firestore > Rules
//  These rules ensure ONLY the logged-in user can read/write their own data.
//  No other user or anonymous visitor can access anyone's data.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: only the owner can read/write their document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
